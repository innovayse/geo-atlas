{
  "name": "@innovayse/geo-atlas",
  "version": "2.0.1",
  "description": "Offline countries, states and cities with multilingual support (EN/RU/HY + 15 languages).",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "test": "ts-node --project tsconfig.json scripts/test.ts"
  },
  "keywords": [
    "countries",
    "cities",
    "states",
    "i18n",
    "translations",
    "offline",
    "armenia",
    "russian",
    "armenian"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.19.0",
    "ts-node": "^10.9.2",
    "typescript": "4.9.5"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false
}
